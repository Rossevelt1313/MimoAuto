# ============================================
# Xiaomi MiMo API Key Generator - Environment Config
# ============================================

# Gmail address used when Gmail mode is selected
GMAIL_USERNAME=yourname@gmail.com

# Gmail App Password (NOT your regular password!)
# Generate one at: https://myaccount.google.com/apppasswords
# Requires 2FA enabled on your Google account.
# Use "Mail" as app and "Other" as device name.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional MiMo invite code
MIMO_INVITE_CODE=your-invite-code

# Headless mode (true = invisible browser, false = watch it work)
HEADLESS=true
